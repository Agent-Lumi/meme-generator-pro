<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>meme-generator-pro | Made by Lumi</title>
    <link rel="manifest" href="manifest.json">
    <script>if("serviceWorker"in navigator)navigator.serviceWorker.register("sw.js")</script>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>💡 meme-generator-pro</h1>
        <p class="subtitle">Create memes with popular templates or upload your own</p>
        
        <!-- Template Gallery -->
        <div class="section">
            <h2>📋 Choose a Template</h2>
            <div class="template-gallery" id="templateGallery">
                <!-- Templates will be loaded by JS -->
            </div>
        </div>

        <!-- Custom Upload -->
        <div class="section upload-section">
            <h2>📤 Or Upload Your Own</h2>
            <div class="upload-area" id="uploadArea">
                <input type="file" id="imageUpload" accept="image/*" hidden>
                <div class="upload-placeholder" onclick="document.getElementById('imageUpload').click()">
                    <span class="upload-icon">📷</span>
                    <p>Click or drag to upload image</p>
                    <small>Supports: JPG, PNG, GIF, WebP</small>
                </div>
            </div>
        </div>

        <!-- Meme Editor -->
        <div class="section editor-section" id="editorSection" style="display: none;">
            <h2>✏️ Edit Your Meme</h2>
            
            <div class="canvas-container">
                <canvas id="memeCanvas"></canvas>
            </div>

            <div class="text-controls">
                <div class="text-inputs">
                    <div class="input-group">
                        <label>Top Text</label>
                        <input type="text" id="topText" placeholder="Enter top text..." maxlength="100">
                    </div>
                    <div class="input-group">
                        <label>Bottom Text</label>
                        <input type="text" id="bottomText" placeholder="Enter bottom text..." maxlength="100">
                    </div>
                </div>
                
                <div class="font-controls">
                    <div class="input-group">
                        <label for="fontSize">Font Size: <span id="fontSizeValue">15%</span></label>
                        <input type="range" id="fontSize" min="5" max="40" value="15" class="slider">
                    </div>
                    
                    <div class="input-group">
                        <label>Text Color</label>
                        <div class="color-picker">
                            <label class="color-option">
                                <input type="radio" name="textColor" value="white" checked>
                                <span class="color-swatch white">⚪</span> White
                            </label>
                            <label class="color-option">
                                <input type="radio" name="textColor" value="black">
                                <span class="color-swatch black">⚫</span> Black
                            </label>
                            <label class="color-option">
                                <input type="radio" name="textColor" value="yellow">
                                <span class="color-swatch yellow">🟡</span> Yellow
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="controls">
                <button onclick="generateMeme()">🔄 Update Preview</button>
                <button onclick="downloadMeme()" class="primary" title="Ctrl+S to download">💾 Download</button>
                <button onclick="copyToClipboard()" class="secondary" title="Ctrl+C to copy">📋 Copy</button>
                <button onclick="resetEditor()" class="secondary">❌ Clear</button>
            </div>
            
            <div class="keyboard-hints">
                <span>⌨️ Shortcuts: Ctrl+S = Download | Ctrl+C = Copy | Escape = Clear</span>
            </div>
        </div>

        <footer>
            Made with 💡 by <a href="https://github.com/Agent-Lumi">Lumi</a>
        </footer>
    </div>
    <script src="app.js"></script>
</body>
</html>
<script>
// API integration ready
const API = {
    async fetch(url, options = {}) {
        const response = await fetch(url, options);
        return response.json();
    }
};
</script>
