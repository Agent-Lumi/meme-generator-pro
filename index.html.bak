<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>meme-generator-pro | Made by Lumi</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>💡 meme-generator-pro</h1>
        <p class="subtitle">Create memes with popular templates or upload your own</p>
        
        <!-- Template Gallery -->
        <div class="section">
            <h2>📋 Choose a Template</h2>
            <div class="template-gallery" id="templateGallery">
                <!-- Templates will be loaded by JS -->
            </div>
        </div>

        <!-- Custom Upload -->
        <div class="section upload-section">
            <h2>📤 Or Upload Your Own</h2>
            <div class="upload-area" id="uploadArea">
                <input type="file" id="imageUpload" accept="image/*" hidden>
                <div class="upload-placeholder" onclick="document.getElementById('imageUpload').click()">
                    <span class="upload-icon">📷</span>
                    <p>Click to upload image</p>
                </div>
            </div>
        </div>

        <!-- Meme Editor -->
        <div class="section editor-section" id="editorSection" style="display: none;">
            <h2>✏️ Edit Your Meme</h2>
            
            <div class="canvas-container">
                <canvas id="memeCanvas"></canvas>
            </div>

            <div class="text-inputs">
                <div class="input-group">
                    <label>Top Text</label>
                    <input type="text" id="topText" placeholder="Enter top text..." maxlength="100">
                </div>
                <div class="input-group">
                    <label>Bottom Text</label>
                    <input type="text" id="bottomText" placeholder="Enter bottom text..." maxlength="100">
                </div>
            </div>

            <div class="controls">
                <button onclick="generateMeme()">🔄 Update Preview</button>
                <button onclick="downloadMeme()" class="primary">💾 Download Meme</button>
                <button onclick="resetEditor()" class="secondary">❌ Clear</button>
            </div>
        </div>

        <footer>
            Made with 💡 by <a href="https://github.com/Agent-Lumi">Lumi</a>
        </footer>
    </div>
    <script src="app.js"></script>
</body>
</html>
<script>
// Usage stats
const stats = JSON.parse(localStorage.getItem('app-stats') || '{}');
stats.visits = (stats.visits || 0) + 1;
stats.lastVisit = new Date().toISOString();
localStorage.setItem('app-stats', JSON.stringify(stats));
console.log('Visits:', stats.visits);
</script>
<script>
// Request notification permission
if ('Notification' in window && Notification.permission === 'default') {
    Notification.requestPermission();
}
function notify(title, body) {
    if (Notification.permission === 'granted') {
        new Notification(title, { body });
    }
}
</script>
<script>
// Export functionality
function exportData(format) {
    const data = document.querySelector('textarea, input')?.value || document.body.innerText;
    const blob = new Blob([data], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'export.' + format;
    a.click();
    URL.revokeObjectURL(url);
}
</script>
<script>
// Undo/Redo history
const history = { past: [], future: [] };
const saveState = () => {
    const state = document.querySelector('textarea, input')?.value;
    if (state) history.past.push(state);
};
document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'z') {
        e.preventDefault();
        if (e.shiftKey && history.future.length) {
            // Redo
            const state = history.future.pop();
            history.past.push(document.querySelector('textarea, input')?.value);
            if (document.querySelector('textarea, input')) document.querySelector('textarea, input').value = state;
        } else if (history.past.length) {
            // Undo
            const state = history.past.pop();
            history.future.push(document.querySelector('textarea, input')?.value);
            if (document.querySelector('textarea, input')) document.querySelector('textarea, input').value = state;
        }
    }
});
document.addEventListener('input', saveState);
</script>
<style>
@media (max-width: 768px) {
    .container { padding: 10px; }
    h1 { font-size: 1.5rem; }
    button { width: 100%; margin: 5px 0; }
}
</style>
<script>
